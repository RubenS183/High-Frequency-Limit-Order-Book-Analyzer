# ============================================================
# High-Frequency Limit Order Book Analyzer — Environment
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ── Application ───────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG          # DEBUG | INFO | WARNING | ERROR
APP_SECRET_KEY=change-me-in-production

# ── API Server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lob_analyzer
POSTGRES_USER=lob_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://lob_user:change-me@localhost:5432/lob_analyzer

# ── TimescaleDB ───────────────────────────────────────────
TIMESCALE_ENABLED=true

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ── Exchange Credentials ──────────────────────────────────
# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_WS_URL=wss://stream.binance.com:9443

# Coinbase
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com

# Kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_WS_URL=wss://ws.kraken.com

# ── Observability ─────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=hf-lob-analyzer
PROMETHEUS_PORT=9090

# ── Feature Store ────────────────────────────────────────
FEATURE_STORE_PATH=./data/features
RAW_DATA_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed
