# ============================================================
# High-Frequency Limit Order Book Analyzer — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
PIPFILE.lock

# Virtual environments
.venv/
venv/
env/
.env
!.env.example

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
benchmark_results/

# Type checking
.mypy_cache/

# Linting
.ruff_cache/

# IDEs
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb
!notebooks/**/*.ipynb

# Data files (large, not for VCS)
data/raw/
data/processed/
data/features/
*.parquet
*.arrow
*.feather
*.csv
!data/samples/*.csv
*.h5
*.hdf5

# Logs
logs/
*.log

# Docker
.docker/

# Alembic
alembic/versions/*.pyc

# Secrets
*.pem
*.key
*.crt
secrets/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
